VITE_DOTBOTS_BASE_URL=http://localhost:8000
VITE_DOTBOTS_WS_URL=ws://localhost:8000
VITE_MQTT_BROKER_HOST=broker.hivemq.com
VITE_MQTT_BROKER_PORT=8884

# If MQTT broker requires authentication, set username and password here:
VITE_MQTT_BROKER_USERNAME=
